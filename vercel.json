{
  "version": 2,
  "builds": [
    {
      "src": "FumazzoAdmin/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "FumazzoAdmin/wsgi.py"
    }
  ],
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "FumazzoAdmin.settings"
    },
    "commands": [
      "python manage.py collectstatic --noinput"
    ]
  }
}
